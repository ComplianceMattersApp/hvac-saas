<?xml version="1.0" encoding="utf-8"?>
<!--
  API 31+ splash override. On Android 12+ the system SplashScreen API ignores
  android:background / windowBackground (used by the pre-31 theme in res/values/
  styles.xml), so the launch theme must set the windowSplashScreen* attributes
  instead. res/values/styles.xml is left unchanged and still serves API 24-30.
-->
<resources>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0F1F35</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>

</resources>
